N8N_ENABLED=true
ENVIRONMENT=dev
# n8n workflows are exposed locally using an ngrok tunnel.
# TEST webhook → use when running the n8n workflow in manual/test mode.
# PROD webhook → use when the n8n workflow is active/published.
N8N_WEBHOOK_TEST=https://postmeiotic-consolatory-haydee.ngrok-free.dev/webhook-test/shadownet-malware
N8N_WEBHOOK_PROD=https://postmeiotic-consolatory-haydee.ngrok-free.dev/webhook/shadownet-malware
N8N_TIMEOUT_SECONDS=8
